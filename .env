# Google OAuth client ID for YouTube playlist access.
# Create a Chrome Extension OAuth client for this extension and paste the client ID below.
VITE_YOUTUBE_CLIENT_ID=96222954484-q8mglnrkc0bfrfns7gb4hbako6j1mbr8.apps.googleusercontent.com

# Optional but strongly recommended: the extension public key keeps your unpacked extension ID stable,
