{
  "name": "Quick Bookmark",
  "description": "Quickly bookmark or open existing bookmarks",
  "version": "3.0.2",
  "manifest_version": 3,
  "permissions": ["bookmarks", "tabs", "tabGroups", "storage", "identity"],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://oauth2.googleapis.com/*",
    "https://accounts.google.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quick Bookmark"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "add": {
      "suggested_key": {
        "default": "Ctrl+D"
      },
      "description": "Open Quick Bookmark popup"
    },
    "open": {
      "suggested_key": {
        "default": "Alt+F"
      },
      "description": "Open Quick Open search to find existing bookmarks"
    }
  }
}
